#!/bin/bash

set -e

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
source "$SCRIPT_DIR/lib/helpers.sh"
source "$SCRIPT_DIR/lib/backup.sh"
DOTFILES_DIR="$HOME/.local/share/dotfiles"
HYPRLAND_CONF="$HOME/.config/hypr/hyprland.conf"

log_info "Configuring hardware-specific settings..."

# Determine which environment and keybindings to use
if has_nvidia_gpu; then
  ENV_CONF="nvidia-env.conf"
  log_detail "Detected NVIDIA GPU"
else
  ENV_CONF="env.conf"
fi

HARDWARE=$(detect_hardware_type)
HELPER=$(get_aur_helper)
if [ "$HARDWARE" = "laptop" ]; then
  spinner "Installing brightnessctl..." $HELPER --noconfirm -S brightnessctl
  KEYBIND_CONF="laptop-keybindings.conf"
  log_detail "Detected laptop hardware"
else
  spinner "Installing ddcutil..." $HELPER --noconfirm -S ddcutil
  KEYBIND_CONF="desktop-keybindings.conf"
  log_detail "Detected desktop hardware"
fi

# Copy the hardware specific templates to the static locations Hyprland expects
mkdir -p "$HOME/.config/hypr/conf"
cp -f "$DOTFILES_DIR/default/hypr/conf/${ENV_CONF}" "$HOME/.config/hypr/conf/env.conf"
cp -f "$DOTFILES_DIR/default/hypr/conf/${KEYBIND_CONF}" "$HOME/.config/hypr/conf/keybindings.conf"

log_success "Hardware-specific configuration applied"

# ===== Keyboard Layout Selection =====
log_info "Setting up keyboard layout..."

LAYOUTS=(
  "us:US English"
  "pl:Polish"
  "sk:Slovak"
  "jp:Japanese"
  "gb:UK English"
  "de:German"
  "fr:French"
  "es:Spanish"
  "it:Italian"
  "pt:Portuguese"
  "ru:Russian"
  "cz:Czech"
  "se:Swedish"
  "no:Norwegian"
  "dk:Danish"
  "fi:Finnish"
  "nl:Dutch"
  "br:Brazilian Portuguese"
  "kr:Korean"
  "cn:Chinese"
  "tr:Turkish"
  "hu:Hungarian"
  "ro:Romanian"
  "ua:Ukrainian"
  "latam:Latin American Spanish"
)

INPUT_CONF="$HOME/.config/hypr/conf/input.conf"

if _has_gum; then
  LAYOUT_OPTIONS=()
  for entry in "${LAYOUTS[@]}"; do
    code="${entry%%:*}"
    name="${entry#*:}"
    LAYOUT_OPTIONS+=("$code - $name")
  done

  SELECTED=$(printf '%s\n' "${LAYOUT_OPTIONS[@]}" | gum choose --header "Select your keyboard layout:" --height 20) || true

  if [ -n "$SELECTED" ]; then
    KB_LAYOUT=$(echo "$SELECTED" | awk '{print $1}')
  else
    KB_LAYOUT="us"
  fi
else
  echo ""
  echo "Available keyboard layouts:"
  local i=1
  for entry in "${LAYOUTS[@]}"; do
    code="${entry%%:*}"
    name="${entry#*:}"
    echo "  $i) $code - $name"
    i=$((i + 1))
  done
  echo ""
  read -p "Enter layout code (e.g. us, pl, sk, jp) [default: us]: " KB_LAYOUT
  KB_LAYOUT="${KB_LAYOUT:-us}"
fi

# Write the input config
cat > "$INPUT_CONF" <<EOF
input {
    kb_layout = $KB_LAYOUT
    kb_variant =
    kb_model =
    kb_options =
    kb_rules =

    follow_mouse = 1

    sensitivity = 0
    touchpad {
        natural_scroll = false
    }
}
EOF

log_success "Keyboard layout set to: $KB_LAYOUT"

# Auto-configure monitors if Hyprland is running
if command -v hyprctl &>/dev/null && hyprctl monitors &>/dev/null 2>&1; then
  log_info "Detecting monitor configuration..."

  MONITORS_CONF="$HOME/.config/hypr/conf/monitors.conf"
  TEMP_CONF=$(mktemp)

  echo "env = GDK_SCALE,1" > "$TEMP_CONF"
  echo "" >> "$TEMP_CONF"

  # Parse hyprctl output and extract highest mode for each monitor
  hyprctl monitors | awk '
    /^Monitor / {
      if (monitor) print "monitor=" monitor "," mode ",auto,1"
      monitor = $2
      gsub(/[()]/, "", monitor)
      mode = ""
      max_refresh = 0
    }
    /availableModes:/ {
      in_modes = 1
      modes_line = $0
      sub(/.*availableModes: /, "", modes_line)

      split(modes_line, modes, " ")
      for (i in modes) {
        if (modes[i] ~ /@/) {
          split(modes[i], parts, "@")
          res = parts[1]
          refresh = parts[2]
          sub(/Hz$/, "", refresh)

          if (refresh + 0 > max_refresh) {
            max_refresh = refresh + 0
            mode = modes[i]
            sub(/Hz$/, "", mode)
          }
        }
      }
    }
    END {
      if (monitor && mode) print "monitor=" monitor "," mode ",auto,1"
    }
  ' >> "$TEMP_CONF"

  # Only update if we got valid output
  if grep -q "^monitor=" "$TEMP_CONF"; then
    mv "$TEMP_CONF" "$MONITORS_CONF"
    log_success "Auto-configured monitor"
  else
    rm -f "$TEMP_CONF"
    log_detail "Could not detect monitor resolution, keeping default config"
  fi
else
  log_detail "Hyprland not running, keeping default monitor config"
fi
